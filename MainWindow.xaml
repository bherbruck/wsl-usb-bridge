<Window
    x:Class="UsbBridge.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UsbBridge"
    Title="WSL USB Bridge">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.DataContext>
            <local:MainViewModel />
        </Grid.DataContext>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <local:TrayIconView />

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
              Background="Transparent">
            <TextBlock Text="WSL USB Bridge"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>

        <Grid x:Name="RootGrid" Grid.Row="1" Margin="16,4,16,16"
              Tag="{Binding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: Bridging toggle (W11 Bluetooth-style) -->
            <Grid Grid.Row="0" Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="USB Bridging"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center" />
                <ToggleSwitch Grid.Column="1"
                              IsOn="{Binding IsRunning, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              MinWidth="0" />
            </Grid>

            <!-- Single scrollable view -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Your devices -->
                    <TextBlock Text="Bridged devices"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,4" />
                    <ItemsRepeater ItemsSource="{Binding ForwardedDevices}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="2" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:DeviceViewModel">
                                <Button Command="{Binding ElementName=RootGrid, Path=Tag.ToggleExpandCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="0" CornerRadius="4">
                                    <StackPanel>
                                        <Grid Padding="4,10" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE88E;" FontSize="16" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding VidPid}"
                                                           FontFamily="Cascadia Code,Consolas"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </StackPanel>
                                        </Grid>
                                        <!-- Expanded actions -->
                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="52,0,12,8" Spacing="8">
                                            <CheckBox Content="Bridge automatically"
                                                      IsChecked="{Binding HasRule, Mode=OneWay}"
                                                      Command="{Binding ElementName=RootGrid, Path=Tag.ToggleDeviceRuleCommand}"
                                                      CommandParameter="{Binding}">
                                                <CheckBox.Resources>
                                                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundUnchecked" Color="Transparent" />
                                                </CheckBox.Resources>
                                            </CheckBox>
                                            <Button Content="{Binding BridgeLabel}"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding ElementName=RootGrid, Path=Tag.BridgeDeviceCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <TextBlock Text="No devices currently bridged"
                               Visibility="{Binding IsForwardedEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Margin="4,8" />

                    <!-- Other devices -->
                    <TextBlock Text="Other devices"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,16,0,4" />
                    <ItemsRepeater ItemsSource="{Binding OtherDevices}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="2" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:DeviceViewModel">
                                <Button Command="{Binding ElementName=RootGrid, Path=Tag.ToggleExpandCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="0" CornerRadius="4">
                                    <StackPanel>
                                        <Grid Padding="4,10" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE88E;" FontSize="16" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding VidPid}"
                                                           FontFamily="Cascadia Code,Consolas"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </StackPanel>
                                        </Grid>
                                        <!-- Expanded actions -->
                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="52,0,12,8" Spacing="8">
                                            <CheckBox Content="Bridge automatically"
                                                      IsChecked="{Binding HasRule, Mode=OneWay}"
                                                      Command="{Binding ElementName=RootGrid, Path=Tag.ToggleDeviceRuleCommand}"
                                                      CommandParameter="{Binding}">
                                                <CheckBox.Resources>
                                                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundUnchecked" Color="Transparent" />
                                                </CheckBox.Resources>
                                            </CheckBox>
                                            <Button Content="{Binding BridgeLabel}"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding ElementName=RootGrid, Path=Tag.BridgeDeviceCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <TextBlock Text="No other devices connected"
                               Visibility="{Binding IsOtherEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Margin="4,8" />

                    <!-- Rules -->
                    <TextBlock Text="Rules"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,16,0,4" />
                    <ItemsRepeater ItemsSource="{Binding Rules}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:RuleViewModel">
                                <Grid Padding="4,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                              VerticalAlignment="Center" MinWidth="0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Pattern}"
                                                   FontFamily="Cascadia Code,Consolas"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding ElementName=RootGrid, Path=Tag.RemoveRuleCommand}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <TextBlock Text="No rules — use Bridge automatically or add a pattern below"
                               Visibility="{Binding IsRulesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Margin="4,8"
                               TextWrapping="Wrap" />

                    <!-- Add Rule -->
                    <Grid Margin="0,4,0,16" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 PlaceholderText="Pattern (e.g. vid:pid)"
                                 Text="{Binding NewPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Code,Consolas" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="Label (optional)"
                                 Text="{Binding NewLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2" Content="Add"
                                Command="{Binding AddRuleCommand}" />
                    </Grid>

                    <!-- Settings -->
                    <TextBlock Text="Settings"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,16,0,4" />
                    <ToggleSwitch Header="Start with Windows"
                                  IsOn="{Binding StartWithWindows, Mode=TwoWay}"
                                  Margin="4,0" />
                    <ToggleSwitch Header="Start minimized"
                                  IsOn="{Binding StartMinimized, Mode=TwoWay}"
                                  Margin="4,0" />

                    <!-- Activity -->
                    <Button Content="View activity log"
                            Command="{Binding OpenLogCommand}"
                            Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
