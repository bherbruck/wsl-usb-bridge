<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="WSL USB Bridge"
           Manufacturer="bherbruck"
           Version="0.1.0"
           UpgradeCode="7E2F4A8B-3C1D-4F5E-9A6B-8D7C2E1F0A3B"
           Scope="perUser"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of WSL USB Bridge is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="WSL USB Bridge" Level="1">
      <ComponentGroupRef Id="PublishFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <!-- Install to LocalAppData\WSL USB Bridge -->
  <StandardDirectory Id="LocalAppDataFolder">
    <Directory Id="INSTALLFOLDER" Name="WSL USB Bridge">

      <Component Id="StartMenuShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <RegistryValue Root="HKCU" Key="Software\WslUsbBridge" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        <Shortcut Id="StartMenuShortcut"
                  Name="WSL USB Bridge"
                  Target="[INSTALLFOLDER]UsbBridge.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Directory="ProgramMenuFolder" />
        <RemoveFolder Id="CleanupStartMenu" Directory="ProgramMenuFolder" On="uninstall" />
      </Component>

    </Directory>
  </StandardDirectory>

  <ComponentGroup Id="PublishFiles" Directory="INSTALLFOLDER">
    <Files Include="$(PublishDir)**" />
  </ComponentGroup>

</Wix>
